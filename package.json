{
  "name": "@bitsocialhq/bitsocial-react-hooks",
  "type": "module",
  "author": "Bitsocial Labs",
  "keywords": [
    "bitsocial"
  ],
  "repository": "github:bitsocialhq/bitsocial-react-hooks",
  "license": "GPL-2.0-only",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc --project config/tsconfig.json",
    "build:watch": "tsc --project config/tsconfig.json --watch",
    "knip": "knip --production --include dependencies,unlisted,binaries --no-progress",
    "knip:full": "knip --no-progress --no-exit-code",
    "test": "vitest run --config config/vitest.config.js",
    "test:coverage": "vitest run --config config/vitest.config.js --coverage.enabled --coverage.provider=istanbul --coverage.reporter=text --coverage.reporter=json --coverage.reporter=json-summary --coverage.reportsDirectory=./coverage",
    "test:coverage:hooks-stores": "yarn test:coverage && node scripts/verify-hooks-stores-coverage.mjs",
    "test:e2e": "yarn test:e2e:mock && yarn test:e2e:chrome",
    "test:e2e:mock": "cross-env MOCK=1 yarn test:e2e:chrome",
    "test:e2e:mock-content": "cross-env MOCK_CONTENT=1 yarn test:e2e:chrome",
    "test:e2e:chrome": "vitest run --config config/vitest-e2e.config.js",
    "test:e2e:firefox": "cross-env FIREFOX=1 vitest run --config config/vitest-e2e.config.js",
    "test:e2e:browser": "yarn test:e2e:chrome",
    "test:server": "rm -rf .plebbit/ && node test/test-server",
    "test:server:wait-on": "wait-on http://localhost:59281 --timeout 120000",
    "test:mock-content": "vitest run --config config/vitest.config.ts src/lib/plebbit-js/plebbit-js-mock-content.donttest.ts",
    "lint": "oxlint src/**/*.{js,ts,tsx}",
    "prettier": "oxfmt src/**/*.{js,ts,tsx} test/**/*.{js,ts,tsx} config/**/*.{js,ts,tsx}",
    "type-check": "tsc --noEmit --project config/tsconfig.json",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "dependencies": {
    "@noble/ed25519": "1.7.5",
    "@plebbit/plebbit-js": "https://github.com/plebbit/plebbit-js.git#10ed04e3866dd986a7f802bc9efd027f0e7d465b",
    "@plebbit/plebbit-logger": "https://github.com/plebbit/plebbit-logger.git",
    "assert": "2.0.0",
    "ethers": "5.8.0",
    "localforage": "1.10.0",
    "lodash.isequal": "4.5.0",
    "memoizee": "0.4.15",
    "multiformats": "13.4.2",
    "peer-id": "0.16.0",
    "quick-lru": "5.1.1",
    "uint8arrays": "3.1.1",
    "uuid": "11.1.0",
    "viem": "2.45.0",
    "zustand": "4.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8"
  },
  "resolutions": {
    "vite": "npm:rolldown-vite@7.3.1",
    "tar": "7.5.10",
    "minimatch": "3.1.3",
    "elliptic": "6.6.1",
    "bn.js": "5.2.3",
    "**/elliptic/bn.js": "4.12.3",
    "jose": "4.15.5",
    "lodash": "4.17.23",
    "tmp": "0.2.4",
    "@tootallnate/once": "3.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@tsconfig/recommended": "1.0.13",
    "@types/lodash.isequal": "4.5.6",
    "@types/memoizee": "0.4.8",
    "@types/node": "22.19.13",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.6",
    "@types/uuid": "11.0.0",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-istanbul": "4.0.18",
    "commitizen": "4.3.1",
    "conventional-changelog-cli": "4.1.0",
    "cross-env": "10.0.0",
    "cz-conventional-changelog": "3.3.0",
    "husky": "4.3.8",
    "jsdom": "27.3.0",
    "knip": "5.85.0",
    "kubo": "0.39.0",
    "lint-staged": "12.3.8",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "playwright": "1.56.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tcp-port-used": "1.0.2",
    "tempy": "1.0.1",
    "typescript": "5.9.3",
    "vite": "npm:rolldown-vite@7.3.1",
    "vitest": "4.0.18",
    "wait-on": "9.0.3"
  },
  "lint-staged": {
    "{src,test,config}/**/*.{cjs,js,jsx,ts,tsx}": [
      "oxfmt --write"
    ]
  },
  "husky": {
    "hooks": {
      "prepare-commit-msg": "exec < /dev/tty && cz --hook || true",
      "pre-commit": "lint-staged"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "knip": {
    "ignoreDependencies": [
      "assert",
      "@vitest/browser",
      "vite"
    ],
    "ignoreFiles": [
      "config/vitest-empty-alias.js",
      "scripts/coverage-gaps.mjs",
      "scripts/coverage-triage.mjs",
      "src/global.d.ts",
      "src/lib/plebbit-js/plebbit-js-mock-content.donttest.ts",
      "test/browser-plebbit-js-mock/**/*.test.js",
      "test/browser-plebbit-js-mock-content/**/*.test.js"
    ],
    "ignoreIssues": {
      "src/lib/debug-utils.ts": [
        "exports"
      ]
    }
  }
}
